<div class="container main-container">
    {{#if isLoggedIn}}
        {{!-- SETUP VIEW: Shown before session starts --}}
        <div id="setup-container" class="card card-fly-in mb-4">
            <h2>Start Live Session</h2>
            <p class="text-muted">Set your stakes and initial buy-in to begin tracking.</p>
            <hr>
            <form id="start-session-form">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Stakes (Small / Big)</label>
                        <div class="input-group">
                            <input type="number" id="live-small-blind" class="form-control" placeholder="0.50" required>
                            <span class="input-group-text">/</span>
                            <input type="number" id="live-big-blind" class="form-control" placeholder="1.00" required>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label for="live-buyin" class="form-label">Initial Buy-In ($)</label>
                        <input type="number" id="live-buyin" class="form-control" placeholder="100.00" required>
                    </div>
                    <div class="col-12">
                        <label for="live-location" class="form-label">Location (Optional)</label>
                        <input type="text" id="live-location" class="form-control" placeholder="e.g. MGM Grand or Home Game">
                    </div>
                    <div class="col-12 mt-4">
                        <button type="submit" class="btn btn-primary w-100">Start Session</button>
                    </div>
                </div>
            </form>
        </div>

        {{!-- TRACKER VIEW: Initially hidden until form is submitted --}}
        <div id="tracker-container" class="card card-fly-in" style="display: none;">
            <div class="d-flex justify-content-between align-items-top">
                <div>
                    <h1 id="live-status-title">Live Session</h1>
                    <div class="eyebrow" id="session-mode-indicator">Active Tracking</div>
                </div>
                <div class="text-end">
                    <h2 id="live-timer" style="font-size: 3.5rem; font-weight: 800; margin: 0; font-variant-numeric: tabular-nums;">00:00:00</h2>
                    <p class="metric-label">Elapsed Time</p>
                </div>
            </div>

            <hr style="border-top: 1px solid var(--line); margin: 2rem 0;">

            <div class="stats-grid">
                <div class="metric-card">
                    <p class="metric-label">Total Buy-In</p>
                    <h3 class="metric-value" id="display-buyin">$0.00</h3>
                </div>
                <div class="metric-card">
                    <p class="metric-label">Rebuys</p>
                    <h3 class="metric-value" id="display-rebuys">0</h3>
                </div>
                <div class="metric-card">
                    <p class="metric-label">Current Stakes</p>
                    <h3 class="metric-value" id="display-stakes">- / -</h3>
                </div>
            </div>

            <div class="hero-actions mt-4">
                <button id="rebuy-btn" class="btn btn-secondary">Add Rebuy</button>
                <button id="pause-btn" class="btn btn-outline" style="border: 1px solid var(--line);">Pause Timer</button>
                <button id="end-session-btn" class="btn btn-danger" style="margin-left: auto;">End & Cash Out</button>
            </div>
        </div>

        {{!-- CASHOUT OVERLAY --}}
        <div id="cashout-overlay" class="card card-fly-in mt-4" style="display: none; border: 2px solid var(--focus);">
            <h3>Finish Session</h3>
            <div class="stack">
                <label for="final-cashout">Final Cash Out Amount ($)</label>
                <input type="number" id="final-cashout" step="0.01" placeholder="0.00" class="form-control mb-3">
                <button id="confirm-finish-btn" class="btn btn-primary w-100">Save to History</button>
            </div>
        </div>

        <script src="/resources/js/liveTracker.js"></script>

    {{else}}
        <div class="card card-fly-in">
            <div class="alert alert-warning mb-4" role="alert" style="opacity: 1 !important;">
                You need to be logged in to log sessions. <a href="/login" class="alert-link">Log in here</a>.
            </div>
            <h1>Live Session</h1>
            <p>Please log in to access the live poker session tracker.</p>
            <div class="hero-actions mt-4">
                <button class="btn btn-secondary" disabled>Start Session</button>
            </div>
        </div>
    {{/if}}
</div>